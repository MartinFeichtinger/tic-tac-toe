{
    "configurations": [
        {
            "name": "AVR-ATtiny461A",
            "includePath": [
                "${workspaceFolder}/**",
                "/usr/lib/avr/include" 
            ],
            "defines": [
                "__AVR_ATtiny461A__",
                "F_CPU=8000000UL"
            ],
            "compilerPath": "/usr/bin/avr-gcc",
            "cStandard": "c11",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4

    // also add the Makefile Tools and the AVR-Helper extension to vs code
}